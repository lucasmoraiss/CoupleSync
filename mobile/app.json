{
  "expo": {
    "name": "CoupleSync",
    "slug": "couplesync",
    "scheme": "couplesync",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "newArchEnabled": true,
    "android": {
      "package": "com.couplesync.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      "./plugins/withNotificationListener",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
