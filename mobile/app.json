{
  "expo": {
    "name": "CoupleSync",
    "slug": "couplesync",
    "scheme": "couplesync",
    "version": "1.0.0",
    "orientation": "portrait",
    "updates": {
      "url": "https://u.expo.dev/6cc9e838-76ac-43e0-8448-be42d0345570",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "platforms": [
      "android"
    ],
    "icon": "./assets/icon.png",
    "newArchEnabled": false,
    "android": {
      "package": "com.couplesync.app",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      "./plugins/withNotificationListener",
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "6cc9e838-76ac-43e0-8448-be42d0345570"
      }
    }
  }
}
