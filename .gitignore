# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── .NET build artifacts ────────────────────────────────────────────────────
**/bin/
**/obj/

# ─── .NET sensitive config ───────────────────────────────────────────────────
# Development appsettings contain DB credentials and JWT secrets
**/appsettings.Development.json
**/appsettings.*.json
!**/appsettings.json

# ─── Visual Studio / Rider ───────────────────────────────────────────────────
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.idea/

# ─── Test output artefacts ───────────────────────────────────────────────────
test_output*.txt
TestResults/
coverage/

# ─── Mobile – Node / Expo ────────────────────────────────────────────────────
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/.env
mobile/.env.*
!mobile/.env.example

# Firebase real credentials
mobile/google-services.json
mobile/GoogleService-Info.plist

# Generated by expo-cli (already in mobile/.gitignore, kept here for safety)
mobile/expo-env.d.ts

# ─── Docker ──────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── Uploaded files (local dev) ──────────────────────────────────────────────
backend/src/CoupleSync.Api/uploads/

# ─── OS-generated files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── VS Code workspace settings (keep extensions & recommended, skip personal) ─
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
