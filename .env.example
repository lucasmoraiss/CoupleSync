# CoupleSync — Docker Compose Environment Variables
# Copy this file to .env and fill in the values before running docker-compose up.
# NEVER commit the .env file with real values.

# REQUIRED: JWT signing secret (minimum 32 characters)
JWT__SECRET=generate-a-random-string-at-least-32-chars

# JWT token configuration
JWT__ISSUER=CoupleSync
JWT__AUDIENCE=CoupleSync

# PostgreSQL password for local dev container
POSTGRES_PASSWORD=localdev
